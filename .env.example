# Dev/local only example values.
# Do not commit real secrets and do not treat static credentials as production-safe defaults.

# Host ports exposed by docker compose.
PORT=3000
WEB_PORT=8080

# PostgreSQL password used by the local self-hosted baseline.
DB_PASSWORD=change-me-local-only

# Optional server log level.
LOG_LEVEL=info

# Optional 32-byte hex key for application-level scan data encryption in the server.
# Generate with: openssl rand -hex 32
STRONGHOLD_ENCRYPTION_KEY=

# AWS credentials option 1: environment variables.
# Supported for local/self-hosted usage, but do not make static credentials the default choice for an exposed deployment.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# AWS credentials option 2: mount ~/.aws read-only and use a named profile.
# Keep IAM permissions minimal and scoped to the discovery actions Stronghold actually needs.
AWS_PROFILE=default

# Example compose override for Linux/macOS:
# services:
#   server:
#     environment:
#       AWS_PROFILE: ${AWS_PROFILE}
#     volumes:
#       - ~/.aws:/home/node/.aws:ro
#
# On Windows, replace ~/.aws with an explicit path such as ${USERPROFILE}\\.aws.
# The main docker-compose.yml intentionally does not mount AWS credentials by default.
