# ============================================
# Build / Docker
# ============================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================
# Database / Redis
# ============================================
POSTGRES_USER=stronghold
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD_20+_CHARS
POSTGRES_DB=stronghold
DATABASE_URL=postgresql://stronghold:CHANGE_ME_POSTGRES_PASSWORD_20+_CHARS@postgres:5432/stronghold?schema=public
DATABASE_POOL_SIZE=10

REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_20+_CHARS

# ============================================
# Object storage (MinIO / S3)
# ============================================
MINIO_ROOT_USER=stronghold_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_20+_CHARS

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=CHANGE_ME_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET_ACCESS_KEY
S3_BUCKET_PREFIX=stronghold-docs
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900
S3_SERVER_SIDE_ENCRYPTION=
S3_SSE_ALGORITHM=
S3_SSE_KMS_KEY_ID=

# ============================================
# Vector store
# ============================================
CHROMADB_URL=http://chroma:8000
CHROMADB_COLLECTION=pra-documents
CHROMADB_API_TOKEN=
VECTOR_DB_OPTIONAL=false

# ============================================
# Auth / Security
# ============================================
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
DOCUMENT_ENCRYPTION_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
DISCOVERY_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_HEX_64

LICENSE_SIGNING_SECRET=CHANGE_ME_IN_PRODUCTION_MIN_64_CHARS
LICENSE_ISSUER=stronghold

# ============================================
# Application
# ============================================
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:3000
CORS_ALLOW_NO_ORIGIN=false

# ============================================
# Frontend public vars (no secrets)
# ============================================
VITE_API_URL=/api
VITE_APP_VERSION=dev
VITE_ENV=development

# ============================================
# Deployment / Multi-tenant
# ============================================
DEPLOYMENT_MODE=saas
AUTO_UPDATE_ENABLED=true
TENANT_SCHEMA_PREFIX=tenant
TENANT_MAX_USERS=50
TENANT_MAX_DOCUMENTS=5000
TENANT_MAX_STORAGE_GB=200
TENANT_MAX_RPM=1200
TENANT_MAX_RUNBOOKS_PER_MONTH=200
LICENSE_FILE_PATH=

# ============================================
# Background workers / cron
# ============================================
DISCOVERY_WORKER_ENABLED=true
DOCUMENT_WORKER_ENABLED=true
DISCOVERY_SCHEDULER_ENABLED=true
API_KEY_ROTATION_ENABLED=true
LICENSE_QUOTA_RESET_ENABLED=true
DRIFT_CHECK_ENABLED=true

CRON_DISCOVERY=*/30 * * * *
CRON_API_KEY_ROTATION=0 */6 * * *
CRON_LICENSE_RESET=0 0 1 * *
CRON_DRIFT_CHECK=0 6 * * 1

HEALTHCHECK_TIMEOUT_MS=2000
HEALTHCHECK_RETRY_DELAY_MS=500
HEALTHCHECK_RETRIES=2

# ============================================
# Upload / document processing
# ============================================
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_MAX_FILES=1
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document
DOCUMENT_DIRECT_UPLOADS_ENABLED=false
RUNBOOK_TEMPLATE_MAX_FILE_SIZE_MB=10
RUNBOOK_TEMPLATE_DIRECT_UPLOADS_ENABLED=false
RUNBOOK_TEMPLATE_ALLOWED_MIME_TYPES=application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.oasis.opendocument.text,text/markdown

ENABLE_OCR=true
OCR_PROVIDER=tesseract
OCR_LANGS=eng+fra
AWS_TEXTRACT_ENABLED=false
AWS_TEXTRACT_REGION=us-east-1
AWS_REGION=us-east-1

# ============================================
# AI / LLM / Classification
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
OPENAI_CIRCUIT_BREAKER_THRESHOLD=0.5
OPENAI_CIRCUIT_BREAKER_OPEN_MS=60000

DOC_CLASSIFICATION_PROVIDER=ml
DOC_CLASSIFICATION_MODEL=bert
DOC_CLASSIFICATION_MODE=zero-shot
DOC_CLASSIFICATION_TIMEOUT_MS=8000
DOC_CLASSIFICATION_MAX_CHARS=8000
DOC_CLASSIFICATION_LABELS=
DOC_CLASSIFICATION_LABEL_MAP=
DOC_CLASSIFICATION_ENDPOINT=
DOC_CLASSIFICATION_API_KEY=
CLASSIFICATION_CACHE_ENABLED=true
CLASSIFICATION_CACHE_TTL_SEC=900

RAG_RECALL_KS=5,10,20
RAG_FUSION_ALPHA=0.5
RAG_RERANKING=rrf
RAG_CROSS_WEIGHTS=

# ============================================
# Cloud provider optional credentials
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GCP_SERVICE_ACCOUNT_KEY=
GCP_PRICING_API_KEY=
AWS_PRICING_REGION=us-east-1

# ============================================
# Integrations / webhooks
# ============================================
N8N_ALERT_WEBHOOK_URL=
N8N_ALERT_WEBHOOK_TOKEN=
N8N_INGESTION_CALLBACK_URL=
N8N_INGESTION_TRIGGER_URL=
N8N_WEBHOOK_TOKEN=
API_PUBLIC_URL=
VAULT_ADDR=
VAULT_TOKEN=

# ============================================
# Monitoring / retention
# ============================================
OTEL_SERVICE_NAME=stronghold-backend
DOC_RETENTION_DAYS=180
EMBEDDING_RETENTION_DAYS=365
EXTRACTION_FAILURE_ALERT_THRESHOLD=0.2
LLM_FAILURE_ALERT_THRESHOLD=0.15

# ============================================
# Discovery / scanning
# ============================================
NMAP_PATH=
ALLOWED_SENSITIVE_DATA_TYPES=ip,email,phone,iban,secret
DLP_YARA_BIN=yara
DLP_YARA_ENABLED=false
DLP_YARA_RULES_PATH=
DOCUMENT_INGESTION_QUEUE_MODE=bullmq
DISCOVERY_SCHEDULER_INTERVAL_MS=60000
SCENARIO_CATALOG_SOURCE_URL=
ALLOW_DEMO_SEED=false
ML_TRAINING_ENABLED=true
ML_TRAINING_INTERVAL_HOURS=24

# ============================================
# Seed / owner
# ============================================
SEED_API_KEY=CHANGE_ME_DEV_API_KEY
SEED_PLAN=PRO
OWNER_EMAIL=mehdi@stronghold.io
OWNER_API_KEY=
OWNER_PASSWORD=CHANGE_ME_AT_FIRST_LOGIN
