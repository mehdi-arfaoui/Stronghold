        "replicationRules": []
      }
    },
    {
      "id": "ZMINIMAL123",
      "name": "example-minimal.com",
      "type": "DNS",
      "provider": "aws",
      "region": "global",
      "availabilityZone": null,
      "tags": {
        "Service": "dns"
