# Server
PORT=3000
NODE_ENV=development

# Database (local dev via docker-compose.dev.yml)
DATABASE_URL=postgresql://stronghold:stronghold@localhost:5432/stronghold

# CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Optional 32-byte hex key for application-level scan data encryption
# Generate with: openssl rand -hex 32
STRONGHOLD_ENCRYPTION_KEY=

# AWS credentials - use the standard AWS credential chain
# Do NOT put credentials here. Use:
#   - AWS_PROFILE for named profiles
#   - AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for env vars
#   - Instance profile for EC2/ECS
