{
  "name": "@stronghold-dr/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stronghold-dr/core": "file:../core",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "graphology": "^0.26.0",
    "helmet": "^7.2.0",
    "prisma": "^5.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.12",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "prebuild": "npm --prefix ../core run build && prisma generate",
    "pretypecheck": "npm --prefix ../core run build && prisma generate",
    "pretest": "npm --prefix ../core run build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "seed:prisma": "npm --prefix ../core run build && tsx prisma/seed.ts",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "npm run seed:prisma"
  }
}
