generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id     String @id @default(cuid())
  name   String
  apiKey String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys                       ApiKey[]
  services                      Service[]
  infraComponents               InfraComponent[]
  scenarios                     Scenario[]
  scenarioCatalogs              ScenarioCatalog[]
  runbookSteps                  RunbookStep[]
  scenarioServices              ScenarioService[]
  ServiceDependency             ServiceDependency[]
  ServiceInfraLink              ServiceInfraLink[]
  documents                     Document[]
  extractedFacts                ExtractedFact[]
  aiExtractionErrors            AiExtractionError[]
  documentExtractionSuggestions DocumentExtractionSuggestion[]
  documentSensitivityReports    DocumentSensitivityReport[]
  documentClassificationFeedbacks DocumentClassificationFeedback[]
  backupStrategies              BackupStrategy[]
  securityPolicies              SecurityPolicy[]
  policyLinks                   SecurityPolicyService[]
  dependencyCycles              DependencyCycle[]
  dependencyCycleLinks          DependencyCycleService[]
  runbooks                      Runbook[]
  auditLogs                     AuditLog[]
  businessProcesses             BusinessProcess[]
  businessProcessLinks          BusinessProcessService[]
  exerciseEvidence              ExerciseEvidence[]

  RunbookTemplate        RunbookTemplate[]
  incidents              Incident[]
  incidentActions        IncidentAction[]
  incidentServices       IncidentService[]
  incidentDocuments      IncidentDocument[]
  exercises              Exercise[]
  notificationChannels   NotificationChannel[]
  risks                  Risk[]
  riskMitigations        RiskMitigation[]
  exerciseRunbooks       ExerciseRunbook[]
  exerciseChecklistItems ExerciseChecklistItem[]
  exerciseResults        ExerciseResult[]
  exerciseAnalyses       ExerciseAnalysis[]
  discoveryJobs          DiscoveryJob[]
  discoveryScanAudits    DiscoveryScanAudit[]
  discoveryResources     DiscoveryResource[]
  discoveryResourceMatches DiscoveryResourceMatch[]
  discoverySchedules     DiscoverySchedule[]
  discoveryFlows         DiscoveryFlow[]
  discoveryResourceChanges DiscoveryResourceChange[]
}

model Service {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name             String
  type             String
  description      String?
  criticality      String
  businessPriority String? // priorité métier fournie par le client
  recoveryPriority Int?

  // Domaine fonctionnel : APP, DB, NETWORK, SECURITY, IAC, GOV, SAAS, DATA...
  domain String?

  continuity           ServiceContinuity?
  dependenciesFrom     ServiceDependency[]      @relation("ServiceDependenciesFrom")
  dependenciesTo       ServiceDependency[]      @relation("ServiceDependenciesTo")
  infraLinks           ServiceInfraLink[]
  scenarioLinks        ScenarioService[]
  backupStrategies     BackupStrategy[]
  policyLinks          SecurityPolicyService[]
  dependencyCycles     DependencyCycleService[]
  risks                Risk[]
  businessProcessLinks BusinessProcessService[]
  incidentServices     IncidentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Risk {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  title       String
  description String?
  threatType  String
  probability Int
  impact      Int
  status      String?
  owner       String?
  processName String?

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  mitigations RiskMitigation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiskMitigation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  riskId String
  risk   Risk   @relation(fields: [riskId], references: [id])

  description          String
  owner                String?
  status               String?
  dueDate              DateTime?
  businessProcessLinks BusinessProcessService[] @relation("RiskMitigationBusinessProcess")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessProcess {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name                  String
  description           String?
  owners                String?
  financialImpactLevel  Int
  regulatoryImpactLevel Int
  interdependencies     String?

  rtoHours   Int
  rpoMinutes Int
  mtpdHours  Int

  impactScore      Float
  criticalityScore Float

  services BusinessProcessService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessProcessService {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  processId String
  process   BusinessProcess @relation(fields: [processId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  riskMitigationId String?
  riskMitigation   RiskMitigation? @relation("RiskMitigationBusinessProcess", fields: [riskMitigationId], references: [id])

  createdAt DateTime @default(now())
}

model ServiceContinuity {
  id        String  @id @default(cuid())
  serviceId String  @unique
  service   Service @relation(fields: [serviceId], references: [id])

  rtoHours   Int
  rpoMinutes Int
  mtpdHours  Int
  notes      String?

  // Champs calculés ou conseillés pour l'utilisateur à partir des définitions RTO/RPO/MTPD
  advisoryNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceDependency {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  fromServiceId String
  toServiceId   String

  fromService Service @relation("ServiceDependenciesFrom", fields: [fromServiceId], references: [id])
  toService   Service @relation("ServiceDependenciesTo", fields: [toServiceId], references: [id])

  dependencyType String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfraComponent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  type        String
  provider    String?
  location    String?
  criticality String?
  isSingleAz  Boolean @default(false)
  notes       String?

  services ServiceInfraLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceInfraLink {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  serviceId String
  infraId   String

  service Service        @relation(fields: [serviceId], references: [id])
  infra   InfraComponent @relation(fields: [infraId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Scenario {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  catalogScenarioId String?
  catalogScenario   ScenarioCatalog? @relation(fields: [catalogScenarioId], references: [id], onDelete: SetNull)

  name           String
  type           String // ex: REGION_LOSS, AZ_LOSS, DB_CORRUPTION...
  description    String?
  impactLevel    String? // low, medium, high
  rtoTargetHours Int? // tolérance globale de reprise pour ce scénario

  services  ScenarioService[]
  steps     RunbookStep[]
  runbooks  Runbook[]
  exercises Exercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScenarioCatalog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  sourceKey String
  name      String
  type      String
  description    String?
  impactLevel    String?
  rtoTargetHours Int?

  recoveryStrategy     String
  estimatedCostLevel   String?
  estimatedCostMin     Float?
  estimatedCostMax     Float?
  estimatedCostCurrency String?

  scenarios Scenario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, sourceKey])
}

model RunbookStep {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  scenarioId String?
  scenario   Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  order                    Int
  title                    String
  description              String?
  estimatedDurationMinutes Int?
  role                     String? // ex: "Equipe Réseau", "Equipe AD"
  blocking                 Boolean @default(false)

  exerciseChecklistItems ExerciseChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScenarioService {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
}

model Document {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  originalName String
  storedName   String // nom de fichier sur disque
  mimeType     String
  size         Int
  storagePath  String // chemin relatif/absolu sur le serveur
  fileHash     String?

  docType                 String? // ex: "ARCHI", "CMDB", "POLICY", "RUNBOOK", ...
  description             String?
  detectedDocType         String?
  detectedMetadata        String? // JSON stringified metadata for heuristiques
  textHash                String?
  vectorizedAt            DateTime?
  textExtractedAt         DateTime?
  ingestionStatus         String    @default("FILE_STORED") // FILE_STORED, QUEUED, TEXT_EXTRACTED, VECTORIZED, ERROR
  ingestionQueuedAt       DateTime?
  ingestionError          String?
  retentionUntil          DateTime?
  embeddingRetentionUntil DateTime?
  isSensitive             Boolean   @default(false)
  protectionStatus        String    @default("NONE")

  // Extraction de texte
  extractionStatus String  @default("PENDING") // PENDING, SUCCESS, FAILED, UNSUPPORTED
  extractionError  String?
  textContent      String? // texte brut extrait (legacy, chiffré de préférence)
  textContentCiphertext String?
  textContentIv         String?
  textContentTag        String?
  ocrStatus        String? @default("NOT_REQUIRED") // NOT_REQUIRED, SKIPPED, SUCCESS, FAILED, DISABLED
  ocrProvider      String? // TESSERACT, AWS_TEXTRACT
  ocrStartedAt     DateTime?
  ocrCompletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extractedFacts        ExtractedFact[]
  aiExtractionErrors    AiExtractionError[]
  extractionSuggestions DocumentExtractionSuggestion[]
  exerciseEvidence      ExerciseEvidence[]
  incidentDocuments     IncidentDocument[]
  sensitivityReport     DocumentSensitivityReport?
  classificationFeedbacks DocumentClassificationFeedback[]

  @@unique([tenantId, textHash])
  @@unique([tenantId, fileHash])
}

model BackupStrategy {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  type             String // full | differential | incremental | continuous | snapshot
  frequencyMinutes Int
  retentionDays    Int
  storageLocation  String?
  encryptionLevel  String?
  compression      Boolean @default(false)
  immutability     Boolean @default(false)
  rtoImpactHours   Int?
  rpoImpactMinutes Int?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityPolicy {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name                String
  policyType          String
  classification      String?
  scope               String?
  controls            String?
  reviewFrequencyDays Int?
  owner               String?

  services SecurityPolicyService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityPolicyService {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  policyId String
  policy   SecurityPolicy @relation(fields: [policyId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DependencyCycle {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  label    String
  severity String?
  notes    String?

  services DependencyCycleService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DependencyCycleService {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  cycleId String
  cycle   DependencyCycle @relation(fields: [cycleId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  roleInCycle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Runbook {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  scenarioId String?
  scenario   Scenario? @relation(fields: [scenarioId], references: [id])

  title                String
  status               String           @default("DRAFT")
  summary              String?
  markdownPath         String?
  pdfPath              String?
  docxPath             String?
  generatedForServices String?
  templateId           String?
  template             RunbookTemplate? @relation(fields: [templateId], references: [id])
  templateNameSnapshot String?
  generatedAt          DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  exerciseRunbooks ExerciseRunbook[]
}

model RunbookTemplate {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  originalName String
  storedName   String
  mimeType     String
  size         Int
  storagePath  String
  format       String
  description  String?
  fileHash     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runbooks Runbook[]

  @@unique([tenantId, fileHash])
}

model Exercise {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id])

  title       String
  description String?
  scheduledAt DateTime
  status      String   @default("PLANNED")

  runbooks       ExerciseRunbook[]
  checklistItems ExerciseChecklistItem[]
  results        ExerciseResult[]
  analyses       ExerciseAnalysis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseRunbook {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  runbookId String
  runbook   Runbook @relation(fields: [runbookId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tenantId, exerciseId, runbookId])
}

model ExerciseChecklistItem {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  runbookStepId String?
  runbookStep   RunbookStep? @relation(fields: [runbookStepId], references: [id])

  order       Int
  title       String
  description String?
  role        String?
  blocking    Boolean @default(false)

  isCompleted Boolean   @default(false)
  notes       String?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseResult {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  status           String
  rtoObservedHours Int?
  comments         String?
  startedAt        DateTime?
  completedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseAnalysis {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  summary           String
  gaps              Json
  correctiveActions Json

  createdAt DateTime @default(now())
}

model ExtractedFact {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String
  document   Document @relation(fields: [documentId], references: [id])

  type       String // ex: "PRA_PCA_FACT"
  category   String // SERVICE, INFRA, RISK, RTO_RPO, OTHER
  label      String
  data       String // JSON string payload of extracted details
  source     String?
  confidence Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentExtractionSuggestion {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  suggestionType String
  label          String
  data           Json
  status         String    @default("PENDING")
  reviewedAt     DateTime?
  reviewNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, documentId])
  @@index([tenantId, status])
}

model ExerciseEvidence {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  title        String
  description  String?
  exerciseType String?
  occurredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, documentId])
}

model DocumentSensitivityReport {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  status        String   @default("COMPLETED")
  findings      Json
  totalFindings Int
  scannedAt     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, documentId])
}

model DocumentClassificationFeedback {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  predictedType       String?
  predictedConfidence Float?
  correctedType       String
  modelName           String?
  notes               String?

  createdAt DateTime @default(now())

  @@index([tenantId, documentId])
}

model AiExtractionError {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documentId String
  document   Document @relation(fields: [documentId], references: [id])

  cause         String
  errorName     String?
  correlationId String?

  createdAt DateTime @default(now())

  @@index([tenantId, documentId])
}

model Incident {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  title           String
  description     String?
  status          String
  detectedAt      DateTime
  responsibleTeam String?

  services  IncidentService[]
  documents IncidentDocument[]
  actions   IncidentAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncidentService {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
}

model IncidentDocument {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  documentId String
  document   Document @relation(fields: [documentId], references: [id])

  createdAt DateTime @default(now())
}

model IncidentAction {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  actionType  String
  description String?
  metadata    Json?

  createdAt DateTime @default(now())
}

model NotificationChannel {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  type          String
  label         String?
  isEnabled     Boolean @default(true)
  n8nWebhookUrl String
  configuration Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ApiRole {
  ADMIN
  READER
  OPERATOR
}

model ApiKey {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  label         String?
  keyHash       String    @unique
  role          ApiRole   @default(OPERATOR)
  lastUsedAt    DateTime?
  lastReviewedAt DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  rotatedFromId String?
  rotatedFrom   ApiKey?   @relation("ApiKeyRotation", fields: [rotatedFromId], references: [id])
  rotatedTo     ApiKey[]  @relation("ApiKeyRotation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  discoveryJobs DiscoveryJob[]
  discoveryScanAudits DiscoveryScanAudit[]
}

model AuditLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  apiKeyId      String?
  apiKey        ApiKey? @relation(fields: [apiKeyId], references: [id])
  path          String
  method        String
  statusCode    Int
  success       Boolean @default(false)
  errorCode     String?
  latencyMs     Int?
  clientIp      String?
  userAgent     String?
  correlationId String?

  createdAt DateTime @default(now())
}

model DiscoveryJob {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  status   String
  jobType  String
  progress Int    @default(0)
  step     String?

  parameters     String?
  resultSummary  String?
  errorMessage   String?

  credentialsCiphertext String?
  credentialsIv         String?
  credentialsTag        String?

  requestedByApiKeyId String?
  requestedByApiKey   ApiKey? @relation(fields: [requestedByApiKeyId], references: [id])

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs DiscoveryScanAudit[]
  discoveryResources DiscoveryResource[]
  discoveryFlows DiscoveryFlow[]
}

model DiscoveryScanAudit {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  jobId String
  job   DiscoveryJob @relation(fields: [jobId], references: [id])

  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  ipRange String

  createdAt DateTime @default(now())
}

model DiscoveryResource {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  jobId String?
  job   DiscoveryJob? @relation(fields: [jobId], references: [id])

  source     String
  externalId String
  name       String
  kind       String
  type       String
  ip         String?
  hostname   String?
  tags       Json?
  metadata   Json?
  fingerprint String

  discoveredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matches     DiscoveryResourceMatch[]
  flowSources DiscoveryFlow[] @relation("DiscoveryFlowSource")
  flowTargets DiscoveryFlow[] @relation("DiscoveryFlowTarget")

  @@index([tenantId, externalId])
  @@index([tenantId, ip])
  @@index([tenantId, hostname])
}

model DiscoveryResourceMatch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  resourceId String
  resource   DiscoveryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  matchType String
  matchId   String
  strategy  String
  score     Float
  status    String

  createdAt DateTime @default(now())

  @@index([tenantId, resourceId])
}

model DiscoveryResourceChange {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  jobId String?
  job   DiscoveryJob? @relation(fields: [jobId], references: [id])

  source     String
  externalId String
  changeType String

  previousFingerprint String?
  newFingerprint      String?
  metadata            Json?

  detectedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, detectedAt])
  @@index([tenantId, changeType])
  @@index([tenantId, source, externalId])
}

model DiscoverySchedule {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name           String
  ipRanges       Json
  cloudProviders Json
  frequency      String
  scheduleConfig Json
  nextRunAt      DateTime
  lastRunAt      DateTime?
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscoveryFlow {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  jobId String?
  job   DiscoveryJob? @relation(fields: [jobId], references: [id])

  sourceResourceId String?
  sourceResource   DiscoveryResource? @relation("DiscoveryFlowSource", fields: [sourceResourceId], references: [id])

  targetResourceId String?
  targetResource   DiscoveryResource? @relation("DiscoveryFlowTarget", fields: [targetResourceId], references: [id])

  sourceIp String?
  targetIp String?
  sourcePort Int?
  targetPort Int?
  protocol  String?
  bytes     Int?
  packets   Int?
  observedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([tenantId, observedAt])
}
