{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"verbatimModuleSyntax\":false}' node --test tests/**/*.test.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.cjs",
    "db:reset": "node -e \"const fs=require('fs');const p=require('path');const db=p.join(__dirname,'prisma','dev.db');if(fs.existsSync(db)){fs.rmSync(db);}\" && prisma db push --force-reset --skip-generate && npm run db:seed",
    "discovery:cli": "node scripts/discovery-cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/s3-request-presigner": "^3.956.0",
    "@prisma/client": "^5.21.1",
    "adm-zip": "^0.5.15",
    "bullmq": "^5.66.4",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "ioredis": "^5.9.0",
    "mammoth": "^1.7.2",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
