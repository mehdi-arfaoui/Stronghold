{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-scenarios",
    "copy-scenarios": "node scripts/copy-scenarios.mjs",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"verbatimModuleSyntax\":false}' node --test tests/**/*.test.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.cjs",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "db:reset": "node -e \"const fs=require('fs');const p=require('path');const db=p.join(__dirname,'prisma','dev.db');if(fs.existsSync(db)){fs.rmSync(db);}\" && prisma db push --force-reset --skip-generate && npm run db:seed",
    "discovery:cli": "node scripts/discovery-cli.js",
    "ml:retrain": "tsx scripts/retrainModels.ts"
  },
