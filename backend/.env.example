DATABASE_URL="postgresql://pra_user:change_me@localhost:5432/pra_platform?schema=public"

OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4.1-mini

# Deployment
DEPLOYMENT_MODE=saas # saas | onpremise
AUTO_UPDATE_ENABLED=true
TENANT_SCHEMA_PREFIX=tenant
TENANT_MAX_USERS=50
TENANT_MAX_DOCUMENTS=5000
TENANT_MAX_STORAGE_GB=200
TENANT_MAX_RPM=1200
TENANT_MAX_RUNBOOKS_PER_MONTH=200
LICENSE_FILE_PATH=

# Object storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change_me_minio
S3_BUCKET_PREFIX=stronghold-docs
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900

# Vector store
CHROMADB_URL=http://localhost:8000
CHROMADB_COLLECTION=pra-documents
CHROMADB_API_TOKEN=

# Drift Detection
DRIFT_CHECK_ENABLED=true
CRON_DRIFT_CHECK="0 6 * * 1" # Every Monday at 6AM
DRIFT_ALERT_EMAIL=
DRIFT_ALERT_WEBHOOK_URL=
